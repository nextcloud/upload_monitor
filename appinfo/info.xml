<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>upload_monitor</id>
	<name>Upload Monitor</name>
	<summary>Monitor directories for upload inactivity</summary>
	<description><![CDATA[Monitor directories for file upload inactivity and receive notifications when no new files have been uploaded within a configured time period.]]></description>
	<version>1.0.0</version>
	<licence>agpl</licence>
	<author>Nextcloud</author>
	<namespace>UploadMonitor</namespace>

	<category>monitoring</category>

	<bugs>https://github.com/nextcloud/server/issues</bugs>

	<dependencies>
		<nextcloud min-version="34" max-version="34"/>
	</dependencies>

	<background-jobs>
		<job>OCA\UploadMonitor\BackgroundJob\CheckInactivity</job>
	</background-jobs>

	<settings>
		<personal>OCA\UploadMonitor\Settings\Personal</personal>
	</settings>
</info>
